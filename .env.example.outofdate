# MQTT Middleware Pro - Environment Variables
# Copy this file to .env and fill in your values
# DO NOT commit .env to git!

# ============================================
# Server Configuration
# ============================================
NODE_ENV=development
SERVER_PORT=3000
SERVER_HOST=localhost

# ============================================
# MQTT Broker Configuration
# ============================================
# Broker URL (alternative to separate host/port/protocol)
# MQTT_BROKER_URL=mqtt://localhost:1883
MQTT_BROKER_HOST=localhost
MQTT_BROKER_PORT=1883
MQTT_BROKER_PROTOCOL=mqtt
MQTT_BROKER_USERNAME=
MQTT_BROKER_PASSWORD=
MQTT_CLIENT_ID=mqtt-middleware-pro
MQTT_RECONNECT_PERIOD=5000
MQTT_CONNECT_TIMEOUT=30000
MQTT_KEEPALIVE=60
MQTT_CLEAN=false

# ============================================
# MQTT Topic Subscriptions
# ============================================
# Topics to subscribe for incoming device messages (wildcards supported)
MQTT_TOPIC_V5008_UPLOAD=V5008Upload/+/+
MQTT_TOPIC_V6800_UPLOAD=V6800Upload/+/+
# Topics for sending commands to devices
MQTT_TOPIC_V5008_DOWNLOAD=V5008Download/+/+
MQTT_TOPIC_V6800_DOWNLOAD=V6800Download/+/+

# ============================================
# Database Configuration (MySQL 8.0)
# ============================================
DB_ENABLED=true
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=mqtt_middleware
DB_USERNAME=root
DB_PASSWORD="Abc#!Dale123"
DB_CONNECTION_LIMIT=10

# ============================================
# Cache Configuration (Memory only for v1.0)
# ============================================
ENABLE_CACHE=true
CACHE_MAX_SIZE=10000
CACHE_DEFAULT_TTL=300
CACHE_MAX_QUEUE_SIZE=1000

# ============================================
# REST API Configuration
# ============================================
API_ENABLED=true
API_PORT=3000
API_HOST=0.0.0.0
API_ENABLE_CORS=true
API_CORS_ORIGINS=*
API_PREFIX=/api/v1
# API_JWT_SECRET=your-secret-key-here
# API_TOKEN_EXPIRY=24h

# ============================================
# Output Module Configuration
# ============================================

# MQTT Relay - Forward SUO messages to downstream MQTT broker
OUTPUT_MQTT_RELAY_ENABLED=false
OUTPUT_MQTT_RELAY_URL=mqtt://localhost:1884
# OUTPUT_MQTT_RELAY_CLIENT_ID=mqtt-relay-001
# OUTPUT_MQTT_RELAY_USERNAME=
# OUTPUT_MQTT_RELAY_PASSWORD=
OUTPUT_MQTT_RELAY_RECONNECT_PERIOD=5000
OUTPUT_MQTT_RELAY_CONNECT_TIMEOUT=30000
OUTPUT_MQTT_RELAY_KEEPALIVE=60
OUTPUT_MQTT_RELAY_QOS=1
OUTPUT_MQTT_RELAY_RETAIN=false
OUTPUT_MQTT_RELAY_TOPIC_PREFIX=middleware
OUTPUT_MQTT_RELAY_INCLUDE_TYPE=true

# WebSocket Server - Real-time updates for UI clients
OUTPUT_WEBSOCKET_ENABLED=false
OUTPUT_WEBSOCKET_PORT=3001
OUTPUT_WEBSOCKET_HOST=0.0.0.0
OUTPUT_WEBSOCKET_PATH=/ws
OUTPUT_WEBSOCKET_HEARTBEAT=30000
OUTPUT_WEBSOCKET_MAX_CLIENTS=100
OUTPUT_WEBSOCKET_COMPRESSION=false

# Webhook Dispatcher - POST to HTTP endpoints
OUTPUT_WEBHOOK_ENABLED=false
# Example: JSON array of endpoint configurations
# OUTPUT_WEBHOOK_ENDPOINTS=[{"id":"endpoint1","url":"https://example.com/webhook","enabled":true}]
OUTPUT_WEBHOOK_ENDPOINTS=[{"id":"endpoint1","url":"https://example.com/webhook","enabled":true}]
OUTPUT_WEBHOOK_MAX_RETRIES=3
OUTPUT_WEBHOOK_RETRY_DELAY=1000
OUTPUT_WEBHOOK_TIMEOUT=10000
OUTPUT_WEBHOOK_MAX_CONCURRENT=10

# ============================================
# Module Configuration (Legacy - kept for compatibility)
# ============================================
MODULE_SMART_HB_ENABLED=true
MODULE_WATCHDOG_ENABLED=true
MODULE_MQTT_RELAY_ENABLED=false
MODULE_WEBSOCKET_ENABLED=true
MODULE_WEBHOOK_ENABLED=false
MODULE_DATABASE_ENABLED=true
MODULE_PROTOCOL_ADAPTER_ENABLED=true

# ============================================
# SmartHB Configuration
# ============================================
MODULE_SMART_HB_QUERY_COOLDOWN=300000
MODULE_SMART_HB_TRIGGER_ON_HEARTBEAT=true

# ============================================
# Protocol Adapter Configuration
# ============================================
MODULE_PROTOCOL_ADAPTER_ENABLED=true
MODULE_PROTOCOL_ADAPTER_DEDUP_WINDOW=1000

# ============================================
# Watchdog Configuration
# ============================================
MODULE_WATCHDOG_ENABLED=true
WATCHDOG_HEALTH_CHECK_INTERVAL=60

# ============================================
# Database Writer Configuration
# ============================================
DB_WRITER_ENABLED=true
DB_WRITER_BATCH_SIZE=100
DB_WRITER_MAX_QUEUE=1000
DB_WRITER_RETRY_COUNT=3
DB_WRITER_QUEUE_TIMEOUT=5000

# ============================================
# Logging Configuration
# ============================================
LOG_LEVEL=debug
LOG_FORMAT=text
LOG_OUTPUT=console
# LOG_FILE_PATH=/var/log/mqtt-middleware/app.log
# LOG_FILE_MAX_SIZE=100M
# LOG_FILE_MAX_FILES=10
