{
  "name": "iot-u-track-middleware",
  "version": "1.0.0",
  "description": "IoT gateway data integration and normalization middleware for V5008 and V6800 devices",
  "main": "dist/src/app.js",
  "type": "module",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "dev": "tsx watch src/app.ts",
    "start": "node dist/src/app.js",
    "dashboardSimple": "cd dashboardSimple && npm run dev",
    "dashboardSimple:build": "cd dashboardSimple && npm run build",
    "dashboard": "cd dashboard && npm run dev",
    "dashboard:build": "cd dashboard && npm run build",
    "simulator": "cd simulator && npm run dev",
    "simulator:build": "cd simulator && npm run build",
    "simulator:start": "cd simulator && npm start",
    "build": "tsc",
    "build:prod": "tsc && esbuild dist/**/*.js --bundle --platform=node --target=node18 --outdir=dist --allow-overwrite",
    "clean": "rm -rf dist",
    "test": "jest && tsx tests/real-messages/real-message-runner.ts",
    "test:unit": "jest --testPathPattern=unit",
    "test:integration": "jest --testPathPattern=integration",
    "test:coverage": "jest --coverage",
    "test:watch": "jest --watch",
    "test:real": "tsx tests/real-messages/real-message-runner.ts",
    "lint": "eslint src tests --ext .ts",
    "lint:fix": "eslint src tests --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "db:migrate": "node scripts/migrate.js",
    "db:clean": "node scripts/db_clean.js",
    "docker:dev": "docker-compose up -d",
    "docker:stop": "docker-compose down",
    "docker:logs": "docker-compose logs -f app"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dalelaibeyond/mqtt-middleware-pro.git"
  },
  "keywords": [
    "mqtt",
    "iot",
    "middleware",
    "v5008",
    "v6800",
    "gateway",
    "binary-protocol",
    "json-protocol"
  ],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/dalelaibeyond/mqtt-middleware-pro/issues"
  },
  "homepage": "https://github.com/dalelaibeyond/mqtt-middleware-pro#readme",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.3.3",
    "@types/ws": "^8.5.14",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "esbuild": "^0.27.3",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jest": "^29.15.0",
    "globals": "^17.4.0",
    "jest": "^30.2.0",
    "prettier": "^3.8.1",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "mqtt": "^5.15.0",
    "mysql2": "^3.18.2",
    "winston": "^3.19.0",
    "ws": "^8.18.0"
  }
}
